    int spanningTree(int V, vector<vector<int>> adj[])
    {
        priority_queue<int,vector<vector<int>>,greater<vector<int>>> pq;
        int sum=0,vis[V]={0};
        pq.push({0,0});
        while(!pq.empty()){
            int wt=pq.top()[0];
            int node=pq.top()[1];
            pq.pop();
            if(vis[node]==0){
                vis[node]=1;
                sum+=wt;
                for(auto it:adj[node]) {
                    int adjNode=it[0];
                    int edW=it[1];
                    if(vis[adjNode]==0) pq.push({edW,adjNode});}
            }
        }
        return sum;
    }

