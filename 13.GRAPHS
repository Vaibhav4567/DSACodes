#include<bits/stdc++.h>
void dfs(int node,vector<int> &vis,stack<int> &st,vector<pair<int,int>> adj[]){
    vis[node]=1;
    for(auto it:adj[node]){
        int v=it.first;
        if(!vis[v]) dfs(v,vis,st,adj);
    }    
    st.push(node);
}
vector<int> shortestPathInDAG(int n, int m, vector<vector<int>> &edges)
{
    vector<pair<int,int>> adj[n];
    for(auto it:edges){
        int u=it[0];
        int v=it[1];
        int wt=it[2];
        adj[u].push_back({v,wt});        
    }

    //Find topo sort
    vector<int> vis(n,0);
    stack<int> st;
    for(int i=0;i<n;i++){
        if(!vis[i]) dfs(i,vis,st,adj);
    }

    vector<int> dist(n,INT_MAX);
    dist[0]=0;

    //Relax edges in stack
    while(!st.empty()){
        int node=st.top();
        st.pop();
        //This important as if add in INT_MAX, value become -ve, values distorted
        //Continue until find source node
        if(dist[node]==INT_MAX) continue;
        for(auto it:adj[node]){
            int v=it.first;
            int wt=it.second;
            int newDist=dist[node]+wt;
            //No need to put adjNode(v) in stack else wrong answer
            if(newDist<dist[v]) dist[v]=newDist; 
        }
    }
    for(int i=0;i<n;i++){
        if(dist[i]==INT_MAX) dist[i]=-1;
    }
    return dist;
}

17. https://ideone.com/TdZ9Wr
 vector<int> shortestPath(int n, vector<vector<int>>&edges, int src) {
    vector<int> adj[n];
    for(auto it:edges){
        adj[it[0]].push_back(it[1]);        
        adj[it[1]].push_back(it[0]);
    }
    vector<int> dist(n,INT_MAX);
    //Remember to make src newDist =0
    dist[src]=0;
    // no need of queue<pair<int,int>> q; (node,distance)
    queue<int> q;
    q.push(src);
    while(!q.empty()){
        int node=q.front();
        q.pop();
        int newDist=dist[node]+1;
        for(auto it:adj[node]){
            if(newDist<dist[it]) {
                dist[it]=newDist;
                q.push(it);
            }
        }
    }
    for(int i=0;i<n;i++){
        if(dist[i]==INT_MAX) dist[i]=-1;
    }
    return dist;
}

