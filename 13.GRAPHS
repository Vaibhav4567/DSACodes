3. https://ideone.com/Sfsbyt
class Solution {
  public:
    // Function to return Breadth First Traversal of given graph.
    vector<int> bfsOfGraph(int V, vector<int> adj[]) {
        vector<int> bfs;
        int vis[V]={0}; 
        queue<int> q;
        q.push(0);
        vis[0]=1;
        while(!q.empty()){
            int node=q.front();
            q.pop();
            bfs.push_back(node);
            for(auto it:adj[node]){
                if(vis[it]!=1) {              //it=adj[node][i]
                    vis[it]=1;
                    q.push(it);
                }
            }
    }
        return bfs;
    }
};

