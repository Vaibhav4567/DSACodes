22. https://ideone.com/V9gidd
class Solution
{
	public:
	//Function to find the shortest distance of all the vertices
    //from the source vertex S.
    vector <int> dijkstra(int V, vector<vector<int>> adj[], int S)
    {
        priority_queue<pair<int,int>,vector<pair<int,int>>,greater<pair<int,int>>>pq;
        vector<int> dist (V,INT_MAX);
        dist[S]=0;
        pq.push({0,S});
        //Only diff b/w 23.Shortest Path in DAG and Dijkstra is Dijkstra Greedy approach
        //In 23 queue elements are popped sequentially
        //Here they are popped on basis of dist array value
        //23 Only in DAG, Dijkstra only limitation -ve wt(Undir) & -ve wt cycle(Directed,Undir)
        //Since in every traversal dist reduces hence infinite loop
        while(!pq.empty()){
            int node=pq.top().second,dis=pq.top().first;
            pq.pop();
            //To use current dist array value and discard prev dist array value
            // if pq has (3,2),(1,2),then (1,2) pops ,in next chance (3,2) thats useless so continue;
            //To resolve this we may use set also
            //Code works without this also
            if(dis>dist[node]) continue;
            for(auto it:adj[node]){
                int adjNode=it[0],wt=it[1];
                //dis=dist[node] in 23 (as pq gives min dist to node and so dist[node] gives)
                int newDist=dis+wt; 
                if(newDist<dist[adjNode]){
                    dist[adjNode]=newDist;
                    pq.push({newDist,adjNode});
                }
            }
        }
        return dist; 
    }
};

23. https://ideone.com/Ucp1Gz
    vector <int> dijkstra(int V, vector<vector<int>> adj[], int S)
    {
        set<pair<int,int>> st;
        vector<int> dist (V,INT_MAX);
        dist[S]=0;
        st.insert({0,S});
        while(!st.empty()){
            auto it=st.begin();  //*(st.begin())
            int node=it->second,dis=it->first; //it.first/second
            st.erase(it);
            // Use line 13 or line 19 
            // Without these lines also code using prioity_queue or this code works
            if(dis>dist[node]) continue; 
            for(auto it:adj[node]){
                int adjNode=it[0],wt=it[1];
                int newDist=dis+wt;
                if(newDist<dist[adjNode]){
                    // if pq has (3,2) then (1,2) comes then (1,2) pop next,so delete (3,2) since it's useless;
                    if(dist[adjNode]!=INT_MAX) st.erase({dist[adjNode],adjNode});
                    dist[adjNode]=newDist;
                    st.insert({newDist,adjNode});
                }
            }
        }
        return dist; 
    }

