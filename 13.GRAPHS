class Solution {
  public:
    // Function to detect cycle in an undirected graph.
    bool dfsisCycle(int start,int parent,vector<int> adj[],vector<int> &vis) {
        vis[start]=1;
        for(auto adjNodes:adj[start]){
            if(adjNodes!=parent&&vis[adjNodes]==1) return true;
            if(vis[adjNodes]!=1){
                if(dfsisCycle(adjNodes,start,adj,vis)) return true;
            }
        }
        return false;
    }
    bool isCycle(int V, vector<int> adj[]) {
        vector<int> vis(V,0);
        for(int i=0;i<V;i++){
            if(vis[i]!=1) {
                if(dfsisCycle(i,-1,adj,vis)) return true;
            }
        }
        return false;
    }
};

