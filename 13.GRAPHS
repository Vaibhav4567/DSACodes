    int kosaraju(int v, vector<vector<int>>& adj)
    {
        stack<int> st;
        int vis[v]={0};
        for(int i=0;i<v;i++){
            if(!vis[i]) dfs1(i,vis,adj,st);
        }
        vector<vector<int>> adjT(v);
        for(int i=0;i<v;i++){
            for(auto it:adj[i]) adjT[it].push_back(i);
        }
        int visT[v]={0},cnt=0;
        while(!st.empty()){
            int node=st.top();
            st.pop();
            if(!visT[node]){
                cnt++;
                dfs2(node,visT,adjT);
            }
        }
        return cnt;
    }

37. https://ideone.com/MWJ6jG
class Solution {
  private:
  void dfs(int node, int parent ,int timer,vector<int> &vis,vector<int> &tin,vector<int> &low,vector<int> &mark , vector<int>adj[]){
      vis[node]=1;
      tin[node]=low[node]=timer;
      timer++;
      int child=0;
      for(auto it: adj[node]){
          if(it==parent) continue;
          if(!vis[it]){
              dfs(it,node,timer,vis,tin,low,mark,adj);
              low[node]=min(low[it],low[node]);
              if(low[it]>=tin[node] && parent!=-1) mark[node]=1;
              child++;
          }
          else{
              low[node]=min(tin[it],low[node]);
          }
      }
      if(child>1&&parent==-1) mark[node]=1;
  }
  public:
    vector<int> articulationPoints(int n, vector<int>adj[]) {
        vector<int> vis(n,0),tin(n,0),low(n,0),mark(n,0);
        for(int i=0;i<n;i++){
            if(!vis[i]) dfs(i,-1,1,vis,tin,low,mark,adj);
        }
        vector<int> points;
        for(int i=0;i<n;i++){
            if(mark[i]==1) points.push_back(i);
        }
        if(points.size()==0) return {-1};
        return points;
    }
};











