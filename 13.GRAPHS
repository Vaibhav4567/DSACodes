vector<int> shortestPath(int n, vector<vector<int>>&edges, int src) {
    vector<int> adj[n];
    for(auto it:edges){
        adj[it[0]].push_back(it[1]);        
        adj[it[1]].push_back(it[0]);
    }
    vector<int> dist(n,INT_MAX);
    //Remember to make src newDist =0
    dist[src]=0;
    queue<pair<int,int>> q;
    q.push({src,0});
    while(!q.empty()){
        auto it=q.front();
        q.pop();
        int node=it.first;
        int newDist=it.second+1;
        for(auto it:adj[node]){
            if(newDist<dist[it]) {
                dist[it]=newDist;
                q.push({it,newDist});
            }
        }
    }
    for(int i=0;i<n;i++){
        if(dist[i]==INT_MAX) dist[i]=-1;
    }
    return dist;
}

19. https://ideone.com/Mks9p7
vector<vector<string>> shortestTransitionPaths(string start, string finish, vector<string>& wordPool)
{
    set<string> st(wordPool.begin(),wordPool.end());
    queue<vector<string>> q;
    q.push({start});
    //To keep track of all words that has been used in previous level till now
    vector<string> usedOnLevel;
    usedOnLevel.push_back(start);
    //to keep track of when level changes
    int level=0;
    vector<vector<string>> ans;
    while(!q.empty()){
        auto vec=q.front();
        q.pop();
        //Differ from Word ladder 1 as remove element from set only after level completes
        //Erase all words that has been used in previous level till now
        if(vec.size()>level){
            if(ans.size()!=0) break;
            level=vec.size(); //level++;
            for(auto it:usedOnLevel) st.erase(it);
            usedOnLevel.clear();
        }
        string word=vec[vec.size()-1]; //vec.back()
        for(int i=0;i<word.size();i++){
            char original=word[i];
            for(char ch='a';ch<='z';ch++){
                word[i]=ch;
                if(st.find(word)!=st.end()){ //st.count(word)!=0
                    vec.push_back(word);
                    q.push(vec);
                    //Mark visited on level
                    usedOnLevel.push_back(word);
                    if(word==finish) ans.push_back(vec);
                    //Remember to pop
                    vec.pop_back();
                }
            }
            word[i]=original;
        }
    }
    return ans;
}

