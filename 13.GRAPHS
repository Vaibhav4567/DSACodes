#include<bits/stdc++.h>
vector<int> topoSort(vector<int> adj[],int k){
    vector<int> indegree(k,0);
    for (int i = 0; i < k; i++) {
        for(auto it:adj[i])
        indegree[it]++;
    }
    queue<int> q;
    for(int i=0;i<k;i++){
        if(indegree[i]==0) q.push(i);
    }
    vector<int> topo;
    while(!q.empty()){
        int node=q.front();
        topo.push_back(node);        
        q.pop();
        for(auto it:adj[node]){
            indegree[it]--;
            if(indegree[it]==0) q.push(it);
        }
    }
    return topo;
}

string getAlienLanguage(vector<string> &dictionary, int k)
{
    int n=dictionary.size();
    vector<int> adj[k];

    //Create adjList is the main task
    for(int i=1;i<n;i++){
        string s1=dictionary[i-1],s2=dictionary[i];
        int size=min(s1.size(),s2.size());
        for(int ptr=0;ptr<size;ptr++){
            if(s1[ptr]!=s2[ptr]){
                adj[s1[ptr]-'a'].push_back(s2[ptr]-'a');
                break;
            }
        }
    }
    
    vector<int> topo=topoSort(adj,k);
    string ans; //ans=""
    for(auto it:topo) ans+=char(it+'a'); //ans+=(it+'a')

    return ans;
}

