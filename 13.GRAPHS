int minimumOperations(int n, int start, int end, vector<int> &a)
{
	 // if(start==end) return 0;
    queue<pair<int,int>> q;
    q.push({0,start});
    set<int> s;
    s.insert(start);
    while(!q.empty()){
        auto it=q.front();
        q.pop();
        int step=it.first;
        int node=it.second;
        if(node==end) return step;
        for(auto it:a){
            int nextVal=(node*it)%1000;
            if(s.find(nextVal)==s.end()) {
                q.push({step+1,nextVal});
                s.insert(nextVal);
                //if(nextVal==end) return step+1;
            } 
        }
    }
    return -1;
