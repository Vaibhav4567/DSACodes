// User function Template for C++

class Solution {
  public:
    void dfs(int src,int des,int i,int j,vector<pair<int,int>>&v,vector<vector<int>>&grid,vector<vector<int>> &vis){
        vis[i][j]=1;
        v.push_back({i-src,j-des});
        int defr[]={-1,1,0,0},defc[]={0,0,-1,1};
        int m=grid.size(),n=grid[0].size();
        for(int mv=0;mv<4;mv++){
            int newr=i+defr[mv],newc=j+defc[mv];
            if(newr>=0&&newc>=0&&newr<m&&newc<n&&!vis[newr][newc]&&grid[newr][newc]==1) dfs(src,des,newr,newc,v,grid,vis);
        }
    }
    int countDistinctIslands(vector<vector<int>>& grid) {
        int m=grid.size(),n=grid[0].size();
        set<vector<pair<int,int>>> s;
        vector<vector<int>> vis(m,vector<int>(n,0));
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(!vis[i][j]&&grid[i][j]==1) {
                    vector<pair<int,int>>v;
                    dfs(i,j,i,j,v,grid,vis);
                    s.insert(v);
                }
            }
        }
        return s.size();
    }
};

8. https://ideone.com/DMDTtg
bool dfs(int node,int vis[],int path[],vector<int> adj[]){
  vis[node]=1;
  path[node]=1;
  for(auto it:adj[node]){
    if(vis[it]&&path[it]) return true;
    if(!vis[it]){
      if(dfs(it,vis,path,adj)) return true;
    }
  }
  path[node]=0;
  return false;
}
int detectCycleInDirectedGraph(int n, vector < pair < int, int >> & edges) {
  // Write your code here.
  vector<int> adj[n+1];
  for(auto it:edges) adj[it.first].push_back(it.second);
  int vis[n+1]={0},path[n+1]={0};
  for(int i=1;i<=n;i++){
    if(!vis[i]){
      if(dfs(i,vis,path,adj)) return true;
    }
  }
  return false;
}

