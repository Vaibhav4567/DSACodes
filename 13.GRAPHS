28. https://ideone.com/1ImPoo
    vector<int> bellman_ford(int V, vector<vector<int>>& edges, int S) {
        vector<int> dist(V,1e8);
        dist[S]=0;
        for(int i=1;i<=V;i++){
            for(auto edge:edges){
                //edge=u,v,wt
                int u=edge[0]; 
                int v=edge[1];
                int wt=edge[2];
                int newDist=dist[u]+wt;
                //If dist[u]==1e8,newDist will  be -ve
                if(dist[u]!=1e8 && newDist<dist[v]){
                    // If dist changes in Nth relaxation means -ve cycle 
                    if(i==V) return {-1};
                    dist[v]=newDist;
                }
            }
        }
        return dist;
    }

