int isSafe(int node,int col,vector<int> &color,vector<vector<int>> &g){
        for(auto it:g[node]){
            if(color[it]==col) return false;
        }
        return true;
    }
    int f(int node,int n,int m,vector<int> &color,vector<vector<int>> &g){
        if(node==n) return true;
        for(int i=1;i<=m;i++){
            if(isSafe(node,i,color,g)){
                color[node]=i;
                if(f(node+1,n,m,color,g)) return true;
                color[node]=0;
            }
        }
        return false;
    }
    bool graphColoring(bool graph[101][101], int m, int n) {
        // your code here
        vector<int> color(n,0);
        vector<vector<int>> g(n);
        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){
                if(graph[i][j]==1) g[i].push_back(j);
            }
        }
        return f(0,n,m,color,g);
    }

