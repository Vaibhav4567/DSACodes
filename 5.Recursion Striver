    void subsetS(vector<int> &arr, int n,int i,int sum,vector<int> &ans){
        if(i==n){
            ans.push_back(sum);
            return;
        }
        subsetS(arr,n,i+1,sum+arr[i],ans);
        subsetS(arr,n,i+1,sum,ans);
    }
    vector<int> subsetSums(vector<int> arr, int N)
    {
        vector<int> ans;
        subsetS(arr,N,0,0,ans);
        return ans;
    }
};

