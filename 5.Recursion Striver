class Solution{
    public:
    int isSafe(int i, int j, int n,vector<vector<int>> &m,vector<vector<int>> & vis){
        if(i<0||j<0||i==n||j==n) return 0;
        if(m[i][j]==0) return 0;
        if(vis[i][j]==1) return 0;
        return 1;
    }
    void f(int i,int j, int n,string &s,vector<string> &ans,vector<vector<int>> &m,vector<vector<int>> & vis){
        if(i==n-1&&j==n-1){
            ans.push_back(s);
            return;
        }
        int r[]={-1,1,0,0},c[]={0,0,-1,1};
        char d[]={'U','D','L','R'};
        for(int k=0;k<4;k++){
            int newR=i+r[k],newC=j+c[k];
            if(isSafe(newR,newC,n,m,vis)==0) continue;
            vis[newR][newC]=1;
            s.push_back(d[k]);
            f(newR,newC,n,s,ans,m,vis);
            s.pop_back();
            vis[newR][newC]=0;
        }
    }
    vector<string> findPath(vector<vector<int>> &m, int n) {
        // Your code goes here
        vector<string> ans;
        string s;
        if(m[0][0]==0||m[n-1][n-1]==0) return ans;
        vector<vector<int>> vis(n,vector<int>(n,0));
        vis[0][0]=1;
        f(0,0,n,s,ans,m,vis);
        return ans;
    }
};

