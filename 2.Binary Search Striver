        int low=INT_MAX,high=INT_MIN;
        for(int i=0;i<m;i++) {
            low=min(low,grid[i][0]);
            high=max(high,grid[i][n-1]);
        }
        int half=(m*n)/2;
        while(low<=high){
            int mid=low+(high-low)/2;
            int count=0;
            for(int i=0;i<m;i++) count+=upperBound(grid[i],mid);
