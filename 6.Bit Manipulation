    vector<int> findPrimeFactors(int n) {
        vector<int> spf(n+1),ans;
        for(int i=0;i<=n;i++) spf[i]=i;
        for(int i=2;i*i<=n;i++){
            if(spf[i]==i){
                for(int j=i*i;j<=n;j+=i) {
                    if(spf[j]==j) spf[j]=i;
                }
            }
        }
        // while(spf[n]!=n){
        //     ans.push_back(spf[n]);
        //     n=n/spf[n];
        // }
        // ans.push_back(n);
        while(n!=1){
            ans.push_back(spf[n]);
            n=n/spf[n];
        }
        return ans;
    }

































