class Solution {
  public:
    // Function to sort an array using Heap Sort.
    void heapify(int ind,int size,vector<int> &arr){
        int largest=ind;
        int leftChild=2*ind+1;
        int rightChild=2*ind+2;
        if(leftChild<size&&arr[leftChild]>arr[largest]) largest=leftChild;
        if(rightChild<size&&arr[rightChild]>arr[largest]) largest=rightChild;
        if(largest==ind) return;
        swap(arr[ind],arr[largest]);
        heapify(largest,size,arr);
    }
    void heapSort(vector<int>& arr) {
        // code here
        int n=arr.size();
        //Make Max heap: via insertion
        for(int i=n/2-1;i>=0;i--) heapify(i,n,arr);
        //Sort: via deletion
        for(int i=n-1;i>=0;i--){
            swap(arr[0],arr[i]);
            heapify(0,i,arr);
        }
    }
};

