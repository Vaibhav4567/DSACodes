// };

class Solution{
    public:
    int maxLen(vector<int>&A, int n)
    {   
        int maxi=0,sum=0;
        map<int,int> preficSumIndex;
        for(int i=0;i<n;i++){
            sum+=A[i];
            //This line is important eg prefix sum array:- 758901/75890/758090
            //In 1st tc maxi=index of 0
            //2nd tc, 3rd case maxi=n
            if(sum==0) maxi=i+1;
            if(preficSumIndex.find(sum)!=preficSumIndex.end()) maxi=max(maxi,i-preficSumIndex[sum]);
            if(preficSumIndex.find(sum)==preficSumIndex.end()) preficSumIndex[sum]=i;
        }
        return maxi;
    }
};

