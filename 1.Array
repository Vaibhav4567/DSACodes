    int longestSubarrayWithSumK(vector<int> a, long long k) {
        int maxi=0,n=a.size();
        int i=0,j=0;
        long long sum=0;
        while(j<n){
            sum+=a[j];
            j++;
            if(sum==k) maxi=max(maxi,j-i);
            while(sum>=k){
                sum-=a[i];
                i++;
                if(sum==k) maxi=max(maxi,j-i);
            }
        }
        return maxi;
    }

15. https://ideone.com/6PHLGV
int longestSubarrayWithSumK(vector<int> a, long long k) {
    int maxi=0,n=a.size();
    long long sum=0;
    unordered_map<long long,int> mpp;
    for(int i=0;i<n;i++){
        sum+=a[i];
        if(sum==k) maxi=i+1;
        long long rem=sum-k;
        if(mpp.find(rem)!=mpp.end()) maxi=max(maxi,i-mpp[rem]);
        if(mpp.find(sum)==mpp.end())mpp[sum]=i;
    }
    return maxi;
}

16. https://ideone.com/RQpdDx
    vector<int> leaders(int a[], int n){
        vector<int> leadersArr;
        int maxi=a[n-1];
        for(int i=n-1;i>=0;i--){
            maxi=max(a[i],maxi);
            if(a[i]>=maxi) leadersArr.push_back(a[i]);
        }
        reverse(leadersArr.begin(),leadersArr.end());
        return leadersArr;
    }

17. https://ideone.com/j8hFdE
    int findLongestConseqSubseq(int arr[], int n)
    {
      //Your code here
      sort(arr,arr+n);
      int lastSmaller=INT_MIN,currSeq=1,lcs=1;
      for(int i=0;i<n;i++){
          if(lastSmaller==arr[i]-1){
              currSeq++;
              lastSmaller=arr[i];
          }
          else if(lastSmaller<arr[i]-1){
              currSeq=1;
              lastSmaller=arr[i];
          }
          lcs=max(lcs,currSeq);
      }
      return lcs;
    }

