    vector<int> findArrayIntersection(vector<int> &arr1, int n, vector<int> &arr2, int m)
    {
        int i,j;
        i=j=0;
        vector<int> ans;
        while(i<n&&j<m)
        {
            if(arr1[i]<arr2[j])
            i++;
            else if(arr1[i]>arr2[j])
            j++;
            else
