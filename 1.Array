26. https://ideone.com/EPZD65
    void merge(long long arr[],long long s,long long mid,long long e,long long int &ans){
        long long i=s,j=mid+1,k=0;
        vector<long long> temp(e-i+1);
        while(i<=mid&&j<=e){
            if(arr[i]<=arr[j]) temp[k++]=arr[i++];
            else{ 
                ans+=mid-i+1;
                temp[k++]=arr[j++];
            }
        }
        while(i<=mid) temp[k++]=arr[i++];
        while(j<=e) temp[k++]=arr[j++];
        i=s;
        for(auto it:temp) arr[i++]=it;
    }
    void mergesort(long long arr[],long long s,long long e,long long int &ans){
        if(s>=e) return;
        long long mid=s+(e-s)/2;
        mergesort(arr,s,mid,ans);
        mergesort(arr,mid+1,e,ans);
        merge(arr,s,mid,e,ans);
    }
    long long int inversionCount(long long arr[], long long n)
    {
        // Your Code Here
        long long int ans=0;
        mergesort(arr,0,n-1,ans);
        return ans;
    }








