    {
        //Your code here
        //return vector with correct order of elements
        vector<int> ans;
        int i=0,j=0;
        while(i<n&&j<m){
            if(arr1[i]==arr2[j]){
                ans.push_back(arr1[i]);
                while(i<n&&arr1[i]==ans.back()) i++;
                while(j<m&&arr2[j]==ans.back()) j++;
            }
            else if(arr1[i]<arr2[j]){
                ans.push_back(arr1[i]);
                while(i<n&&arr1[i]==ans.back()) i++;
            }
            else{
                ans.push_back(arr2[j]);
                while(j<m&&arr2[j]==ans.back()) j++;
            }
        }
        while(i<n){ 
            ans.push_back(arr1[i]);
            while(i<n&&arr1[i]==ans.back()) i++;
        }
        while(j<m){ 
            ans.push_back(arr2[j]);
            while(j<m&&arr2[j]==ans.back()) j++;    
        }
        return ans;
    }

