    void leftRotate(int arr[], int k, int n) 
	{ 
        k%=n;
        int temp[k];
        for(int i=0;i<k;i++) temp[i]=arr[i];
        for(int i=k;i<n;i++) arr[i-k]=arr[i];
        for(int i=n-k;i<n;i++) arr[i]=temp[i-(n-k)];
	}

