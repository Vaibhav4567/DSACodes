        void merge(long long arr1[], long long arr2[], int n, int m) 
        { 
            int left=n-1, right=0;
            while(left>=0&&right<m){
                if(arr1[left]>arr2[right]){
                    swap(arr1[left],arr2[right]);
                    left--;
                    right++;
                }
                else break;
            }
            sort(arr1,arr1+n);
            sort(arr2,arr2+m);
        } 

21. https://ideone.com/rcJ7ic
        void helper(long long a[], long long b[], int left, int right){
            if(a[left]>b[right]) swap(a[left],b[right]);
        }
        void merge(long long arr1[], long long arr2[], int n, int m) 
        { 
            int len=n+m;
            int gap=(len+1)/2;
            while(true){
                int left=0, right=gap;
                while(right<len){
                    if(left<n&&right<n) helper(arr1,arr1,left,right); //arr1.arr1
                    else if(left<n&&right>=n) helper(arr1,arr2,left,right-n); //arr1,ar
                    else helper(arr2,arr2,left-n,right-n); //arr2,arr2
                    left++;
                    right++;
                }
                if(gap==1) break;
                gap=(gap+1)/2;
            }
        } 

22. https://ideone.com/FFnpcp
    vector<int> findTwoElement(vector<int> arr, int n) {
        ll sumN=0,sum=0,sum2N=0,sum2=0;
        sumN=n*(n+1)/2;
        sum2N=n*(n+1)*(2*n+1)/6;
        for(auto it:arr){
            sum+=it;
            sum2+=(ll)it*it;
        }
        ll diff=sum-sumN;
        ll add=(sum2-sum2N)/diff;
        int rep=(diff+add)/2;
        int miss=add-rep;
        return {rep,miss};
    }

23. https://ideone.com/5pWb52
    vector<int> findTwoElement(vector<int> arr, int n) {
        int xr=0;
        for(int i=0;i<n;i++){
            xr^=arr[i];
            xr^=(i+1);
        }
        // cout<<xr;
        int chk=xr&~(xr-1);
        // while(xrr){
        //     if(xrr&1==1) break;
        //     i++;
        //     xrr=xrr>>1;
        // }
        // cout<<i;
        // int chk=pow(10,i);
        // cout<<chk;
        int zero=0,one=0;
        for(int i=0;i<n;i++){
            if(arr[i]&chk==0) zero^=arr[i];
            else one^=arr[i];
            if((i+1)&chk==0) zero^=(i+1);
            else one^=(i+1);
        }
        int cnt=0;
        for(auto it:arr){
            if(it==zero) cnt++;
        }
        if(cnt==2) return {zero,one};
        return {one,zero};
    }

24. https://ideone.com/AbZ5zK
void merge(long long arr[],long long s,long long mid,long long e){
        long long i=s,j=mid+1,k=0;
        vector<long long> temp(e-i+1);
        while(i<=mid&&j<=e){
            if(arr[i]<=arr[j]) temp[k++]=arr[i++];
            else temp[k++]=arr[j++];
        }
        while(i<=mid) temp[k++]=arr[i++];
        while(j<=e) temp[k++]=arr[j++];
        i=s;
        for(auto it:temp) arr[i++]=it;
    }
    long long int mergesort(long long arr[],long long s,long long e){
        if(s>=e) return 0;
        long long mid=s+(e-s)/2;
        long long int ans=0;
        ans+=mergesort(arr,s,mid);
        ans+=mergesort(arr,mid+1,e);
        long long i=s,j=mid+1;
        while(i<=mid){
            while(j<=e&&arr[j]<arr[i]) j++;
            ans+=j-mid-1;
            i++;
        }
        merge(arr,s,mid,e);
        return ans;
    }
    long long int inversionCount(long long arr[], long long n)
    {
        // Your Code Here
        return mergesort(arr,0,n-1);
    }

