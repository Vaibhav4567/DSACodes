                ans.push_back(arr1[i]);
                i++;
                j++;
            }
        }
        return ans;
    }

12. https://ideone.com/6PHLGV
    int longestSubarrayWithSumK(vector<int> a, long long k) {
        int maxi=0,n=a.size();
        long long sum=0;
        unordered_map<long long,int> mpp;
        for(int i=0;i<n;i++){
            sum+=a[i];
            if(sum==k) maxi=i+1;
            long long rem=sum-k;
            if(mpp.find(rem)!=mpp.end()) maxi=max(maxi,i-mpp[rem]);
            if(mpp.find(sum)==mpp.end())mpp[sum]=i;
        }
        return maxi;
    }

13. https://ideone.com/VaybGB
    #include<bits/stdc++.h>
    int longestSubarrayWithSumK(vector<int> a, long long k) {
        int maxi=0,n=a.size();
        int i=0,j=0;
        long long sum=0;
        while(j<n){
            sum+=a[j];
            j++;
            while(sum>k){
                sum-=a[i];
                i++;
            }
            if(sum==k) maxi=max(maxi,j-i);
        }
        return maxi;
    }

