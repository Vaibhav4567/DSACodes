	int print2largest(int arr[], int n) {
	    int max1=arr[0],max2=-1;
	    for(int i=1;i<n;i++){
	        if(arr[i]>max1){
	            max2=max1;
	            max1=arr[i];
	        }
	        else if(arr[i]>max2&&arr[i]<max1)
	            max2=arr[i];
	    }
	    return max2;
	}

