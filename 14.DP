10. https://ideone.com/tOWvWD
    int FindMaxSum(int arr[], int n)
    {
        int prev2=0,prev1=arr[0];
        for(int i=1;i<n;i++){
            int pick=arr[i]+prev2;
            int notpick=0+prev1;
            prev2=prev1;
            prev1=max(pick,notpick);
        }
        return prev1;
    }

11. https://ideone.com/tIcIVX
    int geek(int day,int curr,vector<vector<int>>& points,vector<vector<int>>& dp){
        //Base cndn
        if(day<0) return 0;
        //Since our call start with n
        if(day!=points.size()&&dp[day][curr]!=-1) return dp[day][curr];
        int maxi=0;
        for(int task=0;task<3;task++){
            if(task!=curr) maxi=max(maxi,geek(day-1,task,points,dp));
        }
        if(day==points.size()) return maxi;
        //here points[day][curr] added, in striver point[day][task] in loop
        else return dp[day][curr]=maxi+points[day][curr];
    }
    int maximumPoints(vector<vector<int>>& points, int n) {
        vector<vector<int>> dp(n,vector<int>(3,-1));
        //Call start from (4,3) in striver (3,3)
        return geek(n,3,points,dp);
    }

