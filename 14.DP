4. https://ideone.com/F9InYA
#include <bits/stdc++.h>
int minE(vector<int>& height, int ind,vector<int> dp){
    if(ind==0) return dp[0]=0;
    if(ind==1) return dp[1]=abs(height[1]-height[0]);
    if(dp[ind]!=-1) return dp[ind];
    int x=minE(height,ind-1,dp)+abs(height[ind]-height[ind-1]);
    int y=minE(height,ind-2,dp)+abs(height[ind]-height[ind-2]);
    return dp[ind]=min(x,y);
}
int minE(int ind, vector<int>& height, vector<int>& dp){
    if(ind==0) return dp[0]=0;
    if(ind==1) return dp[1]=abs(height[1]-height[0]);
    if(dp[ind]!=-1) return dp[ind];
    int x=minE(ind-1,height,dp)+abs(height[ind]-height[ind-1]);
    int y=minE(ind-2,height,dp)+abs(height[ind]-height[ind-2]);
    return dp[ind]=min(x,y);
}

int frogJump(int n, vector<int> &heights)
{
    vector<int> dp(n,-1);
    // return minE(heights,n-1,dp);
    return minE(n-1,heights,dp);

}

