//3.Space Optimization
int findWays(vector<int>& arr, int k)
{
	int n=arr.size();
	vector<int> prev(k+1,0),curr(k+1,0);
	//for(int ind=0;ind<n;ind++) dp[ind][0]=1; instead of this 43,44
	prev[0]=1;	
	curr[0]=1;
	if(arr[0]<=k) prev[arr[0]]=1;
	for(int ind=1;ind<n;ind++){
		for(int target=0;target<=k;target++){
			int notTake=prev[target];
			int take=0;
			if(arr[ind]<=target) take=prev[target-arr[ind]];
			curr[target]=(take+notTake)%(1000000007);
		}
		prev=curr;
	}
	return prev[k];
}

20. https://ideone.com/N1uyPJ
// 1.Memoization
int cnt(int ind,int target,vector<int>& arr,vector<vector<int>>& dp){
	if(ind<0) return target==0;
	if(dp[ind][target]!=-1) return dp[ind][target];
	int notTake=cnt(ind-1,target,arr,dp);
	int take=0;
	if(arr[ind]<=target) take=cnt(ind-1,target-arr[ind],arr,dp);
	return dp[ind][target]=(take+notTake)%(1000000007);
}

int findWays(vector<int>& arr, int k)
{
	int n=arr.size();
	vector<vector<int>> dp(n,vector<int>(k+1,-1));
	return cnt(n-1,k,arr,dp);
}

