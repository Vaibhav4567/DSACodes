#include<bits/stdc++.h>
string findLCS(int n, int m,string &s1, string &s2){
	string s="";
    vector<vector<int>> dp(n+1,vector<int>(m+1,0));
    for(int i=1;i<=n;i++){
        for(int j=1;j<=m;j++){
            if(s1[i-1]==s2[j-1]) {dp[i][j]=1+dp[i-1][j-1];}
            else dp[i][j]=max(dp[i-1][j],dp[i][j-1]);
        }
    }
    //Striver method
    int len=dp[n][m];
    for(int i=0;i<len;i++) s+='$';
    int i=n,j=m,index=len-1;
    while(i!=0&&j!=0){
        if(s1[i-1]==s2[j-1]){
            s[index]=s1[i-1];
            i--;
            j--;
            index--;
        }
        else if(dp[i-1][j]>dp[i][j-1]) i--;
        else j--;
    }

    //My Method
    //Continue going left(j--)(prev col) in a row until next value==curr value 
    //When next value<curr value & (s1[i-1]==s2[j-1])->alphabet of 2 string matches store it,i--,j--
