    int matrixMul(int i,int j, int arr[], vector<vector<int>> &dp){
        if(i==j) return 0;
        if(dp[i][j]!=-1) return dp[i][j]; 
        int mini=INT_MAX;
        //i to j-1, mul arr[k], call(i,k) ,call(k+1,j),
        for(int k=i;k<j;k++) {
            int steps=arr[i-1]*arr[k]*arr[j]+matrixMul(i,k,arr,dp)+matrixMul(k+1,j,arr,dp); //arr[i-1] not arr[i]
            mini=min(steps,mini);
        }
        //i+1 to j, mul arr[k-1], call(i,k-1) ,call(k,j),
        // for(int k=i+1;k<=j;k++) {
        //     int steps=arr[i-1]*arr[k-1]*arr[j]+matrixMul(i,k-1,arr,dp)+matrixMul(k,j,arr,dp);
        //     mini=min(steps,mini);
        // }
        return dp[i][j]=mini;
    }
    int matrixMultiplication(int N, int arr[])
    {
        vector<vector<int>> dp(N,vector<int>(N,-1));
        return matrixMul(1,N-1,arr,dp);
    }

