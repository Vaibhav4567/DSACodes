//3.Space Optimization with one row
//curr to prev, inner loop from m to 1,remove prev=curr;
int lcs(string &str1, string &str2){
    int maxi=0,n=str1.size(),m=str2.size();
    vector<int> prev(m+1,0);
    for(int i=1;i<=n;i++){
        for(int j=m;j>=1;j--){
            if(str1[i-1]==str2[j-1]) {
                prev[j]=1+prev[j-1];
                maxi=max(maxi,prev[j]);
            }
            else prev[j]=0;
        }
    }
    return maxi;
}

26. https://ideone.com/jz2KlX
//Keep in mind length of both strings are different unlike lc pallindromic subsequence
int lcs(string &s,string &t){
    int n=s.size();        
    int m=t.size();
    vector<int> prev(m+1,0),curr(m+1,0);
    for(int i=1;i<=n;i++){
        for(int j=1;j<=m;j++){
            if(s[i-1]==t[j-1]) curr[j]=1+prev[j-1];
            else curr[j]=max(prev[j],curr[j-1]);
        }
        prev=curr;
    }
    return prev[m];
}
int canYouMake(string &s1, string &s2){
    int n=s1.size();        
    int m=s2.size();
    //return (n-lcs)+(m-lcs)
    return n+m-2*lcs(s1,s2);
}

27. https://ideone.com/jJJqVS
vector<int> printingLongestIncreasingSubsequence(vector<int> arr, int n) {
    vector<vector<int>> dp(n+1,vector<int>(n+1,0));
    for(int ind=n-1;ind>=0;ind--){
        for(int prev_ind=ind-1;prev_ind>=-1;prev_ind--){
            int len=0+dp[ind+1][prev_ind+1];
            if(prev_ind==-1||arr[ind]>arr[prev_ind]) dp[ind][prev_ind+1]=max(len,1+dp[ind+1][ind+1]);
            else dp[ind][prev_ind+1]=len; 
        }
    }
	int ind=0,j=-1;
	vector<int> lis;
	while(ind<n){
        if(j==-1||arr[ind]>arr[j]){
            if(1+dp[ind+1][ind+1]>dp[ind+1][j+1]){
                lis.push_back(arr[ind]);
                j=ind;
                ind++;
            }
            else ind++;
        }
        else ind++;
    }
    return lis;
}

28. https://ideone.com/pWZu2f
vector<int> printingLongestIncreasingSubsequence(vector<int> arr, int n) {
	// Write your code here
    vector<int> dp(n,1),hash(n,-1),lis;
	int lastIndex=0,maxi=1;
    for(int i=0;i<n;i++){
        for(int j=0;j<i;j++){
        	if(arr[j]<arr[i]&&dp[i]<1+dp[j]){
				dp[i]=1+dp[j];
				hash[i]=j;
			}
        }
		if(dp[i]>maxi){
			lastIndex=i;
			maxi=dp[i];
		}
    }
	while(lastIndex!=-1){
		lis.insert(lis.begin(),arr[lastIndex]);
		lastIndex=hash[lastIndex];
	}
    return lis;
}

29. https://ideone.com/MBlxFn
int longestBitonicSubsequence(vector<int>& arr, int n)
{
	// Write your code here.
    vector<int> dp1(n,1),arr2=arr,dp2(n,1);
	reverse(arr2.begin(),arr2.end());
    for(int i=0;i<n;i++){
        for(int j=0;j<i;j++){
            if(arr[j]<arr[i]) dp1[i]=max(1+dp1[j],dp1[i]);                
			if(arr2[j]<arr2[i]) dp2[i]=max(1+dp2[j],dp2[i]);
        }
    }
	reverse(dp2.begin(),dp2.end());
	int maxi=1;
	for(int i=0;i<n;i++){
		maxi=max(maxi,dp1[i]+dp2[i]-1);
	}
    return maxi;
}

