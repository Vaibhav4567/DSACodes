    int geek(int day,int curr,vector<vector<int>>& points,vector<vector<int>>& dp){
        if(day<0) return 0;
        if(dp[day][curr]!=-1) return dp[day][curr];
        int maxi=0;
        for(int task=0;task<3;task++){
            if(task!=curr) maxi=max(maxi,geek(day-1,task,points,dp));
        }
        //here points[day][curr] added, in striver point[day][task] in loop
        //Runtime err since point[4][3]
        return dp[day][curr]=maxi+points[day][curr];
    }
    int maximumPoints(vector<vector<int>>& points, int n) {
        //To avoid runtime increase size of dp by 1 row,col than points or use if else
        //Our call start with (4,3) while striver with(3,3) hence he inc only col
        //point size n*2
        vector<vector<int>> dp(n+1,vector<int>(3,-1));
        return geek(n,3,points,dp);
    }

13. https://ideone.com/8RUSxI
    int geek(int day,int curr,vector<vector<int>>& points,vector<vector<int>>& dp){
        if(day<0) return 0;
        if(dp[day][curr]!=-1) return dp[day][curr];
        int maxi=0;
        for(int task=0;task<3;task++){
            //Runtime err since point[4][3] after if else not properly removed
            //Why striver used point[day][task] in loop
            //Striver not err since day max n-1, task max 2
            if(task!=curr) maxi=max(maxi,geek(day-1,task,points,dp)+points[day][curr]);
        }
        return dp[day][curr]=maxi;
    }
    int maximumPoints(vector<vector<int>>& points, int n) {
        //To avoid runtime increase size of dp by 1 row,col than points or use if else
        //Our call start with (4,3) while striver with(3,3) hence he inc only col
        //point size n*2
        vector<vector<int>> dp(n+1,vector<int>(3,-1));
        return geek(n,3,points,dp);
    }

14. https://ideone.com/Hc97TA
    int maximumPoints(vector<vector<int>>& points, int n) {
        vector<vector<int>> dp (n,vector<int>(3,-1)) ;
        for(int task=0;task<3;task++) dp[0][task]=points[0][task];
        for(int i=1;i<n;i++){
            dp[i][0]=points[i][0]+max(dp[i-1][1],dp[i-1][2]);
            dp[i][1]=points[i][1]+max(dp[i-1][0],dp[i-1][2]);
            dp[i][2]=points[i][2]+max(dp[i-1][0],dp[i-1][1]);
        }
        return max(dp[n-1][0],max(dp[n-1][1],dp[n-1][2]));
    }

15. https://ideone.com/C40nzv
    int maximumPoints(vector<vector<int>>& points, int n) {
        //Space Optimization
        //We need only previous row to calc. current row
        vector<int> dp(3,-1) ;
        for(int task=0;task<3;task++) dp[task]=points[0][task];
        for(int i=1;i<n;i++){
            vector<int> temp(3,-1);
            temp[0]=points[i][0]+max(dp[1],dp[2]);
            temp[1]=points[i][1]+max(dp[0],dp[2]);
            temp[2]=points[i][2]+max(dp[0],dp[1]);
            dp=temp;
        }
        return max(dp[0],max(dp[1],dp[2]));
    }

