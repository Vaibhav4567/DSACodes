// 3.Space Optimization
#include <bits/stdc++.h> 
int uniquePaths(int m, int n) {
	//Declare -1th row
	vector<int> prev(n,0);
	for(int i=0;i<m;i++){
		vector<int> curr(n,0);
		for(int j=0;j<n;j++){
			if(i==0||j==0) curr[j]=1;
			else {
				int up=prev[j];
				int left=curr[j-1];
				curr[j]=up+left;
			}
		}
		prev=curr;
	}
	return prev[n-1];
}

