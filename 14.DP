//3.Space Optimization in one row
//Just change curr with prev(that is use one row)
//No need to have reverse inner loop for wt as in 0/1 knapsack 
//Since here take depend on curr ith row not (i-1)th row
#include <bits/stdc++.h> 
int unboundedKnapsack(int n, int w, vector<int> &profit, vector<int> &weight)
{
    vector<int>prev(w+1,0);
    for(int wt=0;wt<=w;wt++) prev[wt]=(wt/weight[0])*profit[0];
    for(int ind=1;ind<n;ind++){
        for(int wt=0;wt<=w;wt++){
            int notTake=0+prev[wt];
            int take=0;
            if(weight[ind]<=wt) take=profit[ind]+prev[wt-weight[ind]];
            prev[wt]=max(notTake,take);
        }
    }
    return prev[w];
}

