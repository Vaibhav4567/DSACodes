1. https://ideone.com/S9WNGm
    int minE(vector<int>& height, int ind,vector<int> &dp){
        if(ind==0) return dp[0]=0;
        if(dp[ind]!=-1) return dp[ind];
        int x=minE(height,ind-1,dp)+abs(height[ind]-height[ind-1]);
        int y=INT_MAX;
        if(ind>1) y=minE(height,ind-2,dp)+abs(height[ind]-height[ind-2]);
        return dp[ind]=min(x,y);
    }
    int minimumEnergy(vector<int>& height, int n) {
        vector<int> dp(n,-1);
        return minE(height,n-1,dp);
    }

2. https://ideone.com/bZUPEk
    int minimumEnergy(vector<int>& height, int n) {
        vector<int> dp(n,-1);
        dp[0]=0;
        for(int ind=1;ind<n;ind++)
        {
            int x=dp[ind-1]+abs(height[ind]-height[ind-1]);
            int y=INT_MAX;
            if(ind>1) y=dp[ind-2]+abs(height[ind]-height[ind-2]);
            dp[ind]=min(x,y);
        }
        return dp[n-1];
    }

