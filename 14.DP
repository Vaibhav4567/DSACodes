    int minimizeCost(vector<int>& height, int k) {
        // int dp[n]={0},mini=INT_MAX;
        // return minCost(height,n-1,k,dp,mini);
        int n=height.size();
        int dp[n];
        dp[0]=0;
        for(int i=1;i<n;i++){
            int mini=INT_MAX;
            for(int j=1;j<=k;j++){
                if(i-j<0) break;
                mini=min(mini,dp[i-j]+abs(height[i]-height[i-j]));
            }
            dp[i]=mini;
        }
        return dp[n-1];
    }

6. https://ideone.com/hhBxlD
	int findMax(int *arr, int dp[],int ind){
	    if(ind==0) return arr[ind];
	    int maxi=0;
	    if(ind>1) {
	        if(dp[ind-2]!=0) maxi=max(maxi,dp[ind-2]);
	        else maxi=max(maxi,findMax(arr,dp,ind-2));
	    }
	    if(ind>2) {
	        if(dp[ind-3]!=0) maxi=max(maxi,dp[ind-3]);
	        else maxi=max(maxi,findMax(arr,dp,ind-3));
	    }
	    return dp[ind]=maxi+arr[ind];                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         
	}
	int findMaxSum(int *arr, int n) {
	    int dp[n]={0};
	    return max(findMax(arr,dp,n-1),findMax(arr,dp,n-2));
	}

7. https://ideone.com/xS3iz0
	int findMax(int *arr, int dp[],int ind){
	    if(ind==0) return arr[ind];
	    if(ind<0) return 0;
	    if(dp[ind]!=0) return dp[ind];
	    int pick=arr[ind]+findMax(arr,dp,ind-2);
	    int notpick=0+findMax(arr,dp,ind-1);                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               
	    dp[ind]=max(pick,notpick);  
	}
	int findMaxSum(int *arr, int n) {
	    int dp[n]={0};
	    return findMax(arr,dp,n-1);
	}

