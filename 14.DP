//4.Space Optimization with one row
int cutRod(vector<int> &price, int n)
{
	vector<int> prev(n+1,0);
	for(int len=0;len<=n;len++) prev[len]=price[0]*len;
	for(int ind=1;ind<n;ind++){
		for(int len=0;len<=n;len++){
			int notTake=0+prev[len];
			int take=-1e8;
			int rodLength=ind+1;
			if(rodLength<=len) take=price[ind]+prev[len-rodLength];
			prev[len]=max(take,notTake);
		}
	}
	return prev[n];
}

