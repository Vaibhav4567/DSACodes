bool getPath(TreeNode<int> *root,vector<int> &path, int x){
	if(root==NULL) return false;
	path.push_back(root->data);
	if(root->data==x) return true;
	if(getPath(root->left,path,x)||getPath(root->right,path,x)) return true;
	path.pop_back();
	return false;
}
