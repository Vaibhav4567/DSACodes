bool isLeaf(TreeNode<int> *root){
    if(root->left==NULL&&root->right==NULL) return true;
    return false;
}
void leftans(TreeNode<int> *root,vector<int> &ans){
    if(isLeaf(root)) return;
    ans.push_back(root->data);
    if(root->left) leftans(root->left,ans);    
    else leftans(root->right,ans);
}
void inorder(TreeNode<int> *root,vector<int> &ans){
    if(root==NULL) return;
    inorder(root->left,ans);
    if(isLeaf(root)){ 
        ans.push_back(root->data);
        return;
    }
    inorder(root->right,ans);
}
void rightans(TreeNode<int> *root,vector<int> &temp){
    if(isLeaf(root)) return;
    temp.push_back(root->data);
    if(root->right) rightans(root->right,temp);    
    else rightans(root->left,temp);
}
vector<int> traverseBoundary(TreeNode<int> *root)
{
    if(root==NULL) return {};
	vector<int> ans,temp;
    if(!isLeaf(root)) ans.push_back(root->data);;
    if(root->left!=NULL) leftans(root->left,ans);
    inorder(root,ans);    
    if(root->right!=NULL) rightans(root->right,temp);
    int n=temp.size();
    for(int i=n-1;i>=0;i--) ans.push_back(temp[i]);
    return ans;
}

