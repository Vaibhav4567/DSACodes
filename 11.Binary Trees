#include<bits/stdlib.h>
#include <unordered_map>
unordered_map<BinaryTreeNode<int>*,BinaryTreeNode<int>*> mpp;
BinaryTreeNode<int>* markParent(BinaryTreeNode<int>*root,int start){
    BinaryTreeNode<int>* target;
    queue<BinaryTreeNode<int>*> q;
    q.push(root);
    while(!q.empty()){
        BinaryTreeNode<int>* node=q.front();
        q.pop();
        if(node->data==start) target=node;
        if(node->left){
            mpp[node->left]=node;
            q.push(node->left);
        }
        if(node->right){
            mpp[node->right]=node;
            q.push(node->right);
        }
    }
    return target;
}
int timeToBurnTree(BinaryTreeNode<int>* root, int start)
{
    BinaryTreeNode<int>* target=markParent(root,start);
    unordered_map<BinaryTreeNode<int>*,int> vis;
    int time=0;
    queue<BinaryTreeNode<int>*> q;
    q.push(target);
    vis[target]=1;
    while(!q.empty()){
        int size=q.size();
        time++;
        for(int i=0;i<size;i++){
            BinaryTreeNode<int>* node=q.front();
            q.pop();
            if(node->left && vis[node->left]==0){
                q.push(node->left);
                vis[node->left]=1;
            }
            if(node->right && vis[node->right]==0){
                q.push(node->right);
                vis[node->right]=1;
            }
            if(mpp[node] && vis[mpp[node]]==0){
                q.push(mpp[node]);
                vis[mpp[node]]=1;
            }
        }
    }
    return time-1;
}
















































