class MyStack {
  private:
    StackNode *top;
  public:
    void push(int x) {
        // code here
        StackNode *temp=new StackNode(x);
        if(top==NULL){
            top=temp;
        }
        else{
            temp->next=top;
            top=temp;
        }
    }

    int pop() {
        // code here
        if(top==NULL) return -1;
        int ans=top->data;
        StackNode *temp=top;
        top=top->next;
        delete temp;
        return ans;
    }

    MyStack() { top = NULL; }
};

