    int celebrity(vector<vector<int> >& mat) {
        // code here
        int t=0,b=mat.size()-1;
        while(t<b){
            if(mat[t][b]==1) t++;
            else if(mat[b][t]==1) b--;
            else {
                t++;
                b--;
            }
        }
        if(b>t) return -1;
        int sumR=0,sumC=0;
