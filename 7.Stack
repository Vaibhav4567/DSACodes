/*
class MyQueue {
private:
    int arr[100005];
    int front;
    int rear;

public :
    MyQueue(){
    front=0;rear=0;
    }
    void push(int);
    int pop();
};
 */

// Function to push an element x in a queue.
void MyQueue ::push(int x) {
    // Your Code
    arr[rear]=x;
    rear++;
}

// Function to pop an element from queue and return that element.
int MyQueue ::pop() {
    // Your Code
    if(front==0&&rear==0) return -1;
    int ans=arr[front];
    front++;
    if(front==rear){
        front=rear=0;
    }
    return ans;
}
}

