class Solution {
  public:
    // Function to find the length of a loop in the linked list.
    int countNodesinLoop(Node *head) {
        // Code here
        Node *slow=head,*fast=head;
        int ans=0;
        while(fast&&fast->next){
            slow=slow->next;
            fast=fast->next->next;
            if(slow==fast){
                while(1){
                    slow=slow->next;
                    ans++;
                    if(slow==fast) return ans;
                }
            }
        }
        return 0;
    }
};

