class Solution {
public:
    int f(ListNode* head){
        if(head==NULL) return 1;
        int carry=f(head->next);
        int sum=carry+head->val;
        head->val=sum%10;
        return sum/10;
    }
    ListNode* plusOne(ListNode* head) {
        int carry=f(head);
        if(carry==0) return head;
        ListNode* newHead=new ListNode(1);
        newHead->next=head;
        return newHead;
    }
};

