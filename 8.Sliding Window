    int longestKSubstr(string s, int k) {
    // your code here
        int l=0,r=0,n=s.size(),maxi=0;
        unordered_map<char,int> mpp;
        while(r<n){
            mpp[s[r]]++;
            while(mpp.size()>k){
                mpp[s[l]]--;
                if(mpp[s[l]]==0) mpp.erase(s[l]);
                l++;
            }
            if(mpp.size()==k) maxi=max(r-l+1,maxi);
            r++;
        }
        return maxi!=0?maxi:-1;
